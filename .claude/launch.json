{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "WikiMind",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-c", "import os,http.server,socketserver; httpd=socketserver.TCPServer(('',int(os.environ.get('PORT',3000))),http.server.SimpleHTTPRequestHandler); httpd.serve_forever()"],
      "autoPort": true
    }
  ]
}
